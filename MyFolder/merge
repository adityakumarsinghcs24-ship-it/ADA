#include<stdio.h>
void mg(int arr[],int l,int mid,int r){
    int i=l,k=0,j=mid+1,t[r-l+1];
    while(i<=mid && j<=r){
        t[k++]=(arr[i]<arr[j]?arr[i++] : arr[j++]);
    }
    while(i<=mid)t[k++]=arr[i++];
    while(j<=r)t[k++]=arr[j++];
    for(i=l,k=0;i<=r;i++,k++){
        arr[i]=t[k];
    }
}
void ms(int arr[], int l,int r){
    if(l<r){
        int mid=l+(r-l)/2;
        ms(arr,l,mid);
        ms(arr,mid+1,r);
        mg(arr,l,mid,r);
    }
}

int main(){
    int n;
    printf("Enter size of arr: ");
    scanf("%d",&n);
    int arr[n];
    printf("Enter elements of array: \n");
    for(int i=0;i<n;i++){
        
        scanf("%d",&arr[i]);
    }
    ms(arr,0,n-1);
    printf("SOrted array: \n");
    for(int i=0;i<n;i++){
        printf("%d ",arr[i]);
    }
}
